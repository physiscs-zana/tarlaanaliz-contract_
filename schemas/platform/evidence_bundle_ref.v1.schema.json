{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://api.tarlaanaliz.com/schemas/platform/evidence_bundle_ref.v1.schema.json",
  "title": "PlatformEvidenceBundleRef",
  "description": "Platform tarafı kanıt paketi referansı — KR-072 kanonik. Merkezi sistemde saklanan, dataset'e ait tüm kanıt dökümanlarının toplu referansı. Audit ve compliance sorgularında kullanılır.",
  "type": "object",
  "unevaluatedProperties": false,
  "required": ["bundle_id", "dataset_id", "mission_id", "evidence_chain", "chain_complete", "created_at"],
  "properties": {
    "bundle_id": {"type": "string", "format": "uuid"},
    "dataset_id": {"type": "string", "format": "uuid"},
    "mission_id": {"type": "string", "format": "uuid"},
    "field_id": {"type": ["string", "null"], "format": "uuid"},
    "evidence_chain": {
      "type": "object",
      "properties": {
        "intake_manifest_id": {"type": ["string", "null"], "format": "uuid"},
        "edge_scan_report_id": {"type": ["string", "null"], "format": "uuid"},
        "edge_verification_report_id": {"type": ["string", "null"], "format": "uuid"},
        "calibration_certificate_id": {"type": ["string", "null"], "format": "uuid"},
        "calibration_result_id": {"type": ["string", "null"], "format": "uuid"},
        "platform_scan_report_id": {"type": ["string", "null"], "format": "uuid"},
        "platform_verification_report_id": {"type": ["string", "null"], "format": "uuid"},
        "qc_report_id": {"type": ["string", "null"], "format": "uuid"},
        "attestation_ids": {"type": "array", "items": {"type": "string", "format": "uuid"}}
      },
      "description": "Kanıt zincirindeki her aşamaya ait döküman referansları."
    },
    "chain_complete": {"type": "boolean", "description": "Tüm zorunlu kanıt dökümanları mevcut mu?"},
    "current_status": {"$ref": "../../enums/dataset_status.enum.v1.json"},
    "created_at": {"type": "string", "format": "date-time"},
    "updated_at": {"type": ["string", "null"], "format": "date-time"}
  },
  "x-kr-ref": ["KR-072"],
  "x-ssot-version": "1.2.0",
  "x-updated": "2026-03-03"
}
