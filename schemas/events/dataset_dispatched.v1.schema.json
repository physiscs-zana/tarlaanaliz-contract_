{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://api.tarlaanaliz.com/schemas/events/dataset_dispatched.v1.schema.json",
  "title": "DatasetDispatched",
  "description": "Dataset worker node'a gönderildi — KR-072. analysis_job oluşturuldu.",
  "type": "object",
  "unevaluatedProperties": false,
  "required": [
    "event_id",
    "event_type",
    "dataset_id",
    "status_from",
    "status_to",
    "occurred_at",
    "correlation_id"
  ],
  "properties": {
    "event_id": {
      "type": "string",
      "format": "uuid",
      "description": "Olay benzersiz kimliği."
    },
    "event_type": {
      "type": "string",
      "const": "DATASET.DISPATCHED",
      "description": "Olay tipi sabiti."
    },
    "dataset_id": {
      "type": "string",
      "format": "uuid"
    },
    "mission_id": {
      "type": [
        "string",
        "null"
      ],
      "format": "uuid"
    },
    "status_from": {
      "const": "CALIBRATED_SCANNED_CENTER_OK"
    },
    "status_to": {
      "const": "DISPATCHED_TO_WORKER"
    },
    "occurred_at": {
      "type": "string",
      "format": "date-time"
    },
    "correlation_id": {
      "type": "string",
      "description": "İzlenebilirlik için korelasyon ID. PII içermez."
    },
    "actor": {
      "type": [
        "string",
        "null"
      ],
      "description": "Olayı tetikleyen servis veya kullanıcı ID."
    },
    "payload": {
      "type": "object",
      "properties": {
        "worker_id": {
          "type": "string"
        },
        "analysis_job_id": {
          "type": "string",
          "format": "uuid"
        },
        "batch_id": {
          "type": [
            "string",
            "null"
          ],
          "format": "uuid"
        }
      }
    }
  },
  "x-kr-ref": [
    "KR-072",
    "KR-070"
  ],
  "x-ssot-version": "1.2.0",
  "x-updated": "2026-03-03"
}