{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://api.tarlaanaliz.com/schemas/events/dataset_analyzed.v1.schema.json",
  "title": "DatasetAnalyzed",
  "description": "Dataset YZ analizi tamamlandı — KR-017 + KR-072.",
  "type": "object",
  "unevaluatedProperties": false,
  "required": [
    "event_id",
    "event_type",
    "dataset_id",
    "status_from",
    "status_to",
    "occurred_at",
    "correlation_id"
  ],
  "properties": {
    "event_id": {
      "type": "string",
      "format": "uuid",
      "description": "Olay benzersiz kimliği."
    },
    "event_type": {
      "type": "string",
      "const": "DATASET.ANALYZED",
      "description": "Olay tipi sabiti."
    },
    "dataset_id": {
      "type": "string",
      "format": "uuid"
    },
    "mission_id": {
      "type": [
        "string",
        "null"
      ],
      "format": "uuid"
    },
    "status_from": {
      "const": "DISPATCHED_TO_WORKER"
    },
    "status_to": {
      "const": "ANALYZED"
    },
    "occurred_at": {
      "type": "string",
      "format": "date-time"
    },
    "correlation_id": {
      "type": "string",
      "description": "İzlenebilirlik için korelasyon ID. PII içermez."
    },
    "actor": {
      "type": [
        "string",
        "null"
      ],
      "description": "Olayı tetikleyen servis veya kullanıcı ID."
    },
    "payload": {
      "type": "object",
      "properties": {
        "analysis_job_id": {
          "type": "string",
          "format": "uuid"
        },
        "model_version": {
          "type": "string"
        },
        "results_summary": {
          "type": "object"
        }
      }
    }
  },
  "x-kr-ref": [
    "KR-017",
    "KR-072"
  ],
  "x-ssot-version": "1.2.0",
  "x-updated": "2026-03-03"
}